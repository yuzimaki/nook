# kimi · env example
#
# 0 required env var for default ship · V2 走 client-side IndexedDB + LLM key
# 存浏览器 (settings page). 想接 own backend / MCP gateway 才填以下:

# kimi gateway URL (own MCP / custom backend, 默认空 = 不接)
# NEXT_PUBLIC_KIMI_GATEWAY=https://your-backend.example.com

# build mode flag · kimi-room | kimi-airp (default kimi-room)
# NEXT_PUBLIC_KIMI_MODE=kimi-room

# server-side embedding API key (仅 MemoryStore 默认 IndexedDB 不需要;
# 接 Supabase + pgvector 时才填)
# OPENAI_API_KEY=sk-...
